# Database (SQLite)
# Production: DATABASE_URL="file:/opt/nixpanel/data/nixpanel.db"
# Development: DATABASE_URL="file:./dev.db"
DATABASE_URL="file:./dev.db"

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_SECRET=""
JWT_REFRESH_SECRET=""

# Server
PORT=4000
HOST=127.0.0.1
NODE_ENV=production

# Licensing
LICENSING_SERVER_URL="https://license.nixpanel.io"
LICENSE_KEY=""
