# Database
DATABASE_URL="mysql://nixpanel:password@localhost:3306/nixpanel"

# JWT
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-to-another-long-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
NODE_ENV="production"
NIXSERVER_PORT=2087
NIXCLIENT_PORT=2083
HOST="0.0.0.0"

# Admin
ADMIN_USERNAME="root"
ADMIN_PASSWORD="change-this-password"
ADMIN_EMAIL="admin@localhost"

# Paths
HOME_DIR="/home"
NGINX_SITES_DIR="/etc/nginx/sites-available"
NGINX_ENABLED_DIR="/etc/nginx/sites-enabled"
APACHE_SITES_DIR="/etc/apache2/sites-available"
APACHE_ENABLED_DIR="/etc/apache2/sites-enabled"
BIND_ZONES_DIR="/etc/bind/zones"
CERTBOT_WEBROOT="/var/www/letsencrypt"

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Features
ENABLE_TERMINAL=true
WEBSOCKET_STATS_INTERVAL=5000

# Modular admin sections
# Use "all" to enable every bundled module, or a comma-separated list such as:
# NIXSERVER_MODULES=server-configuration,accounts,dns,email,ssl,services,system
NIXSERVER_MODULES=all
